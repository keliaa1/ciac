.error-section{text-align:center;margin:6rem auto 10rem;max-width:600px}.error-illustration{width:250px;height:250px;background-color:var(--ligjt-text);border-radius:50%;margin:0 auto 3rem;display:flex;align-items:center;justify-content:center;overflow:hidden;box-shadow:0 20px 40px rgba(0,0,0,.05);position:relative;border:2px solid var(--primary-green)}.error-illustration img{width:100%;height:100%;object-fit:cover;opacity:.9}.error-section h1{font-family:var(--font-heading);font-size:5rem;font-style:italic;line-height:1;margin-bottom:2rem;letter-spacing:-2px}.error-section p{color:var(--gray-text);font-size:1.05rem;line-height:1.8;margin-bottom:3rem;max-width:500px;margin-left:auto;margin-right:auto}.error-actions{display:flex;justify-content:center;gap:1.5rem}.error-actions .btn{display:flex;align-items:center;gap:.5rem;font-family:'Courier New',Courier,monospace;font-family:var(--font-body);font-weight:600;text-transform:uppercase;letter-spacing:1px;padding:1rem 2rem}.error-actions svg{width:16px;height:16px;fill:currentColor}@media (max-width:768px){.error-section{margin:4rem auto}.error-section h1{font-size:3rem}.error-section p{font-size:.9rem}}