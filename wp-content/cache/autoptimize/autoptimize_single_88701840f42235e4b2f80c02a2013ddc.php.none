.newsletter-hero{display:flex;justify-content:space-between;margin:5rem 0 4rem}.newsletter-hero-content{flex:1.2}.newsletter-hero-content h1{font-size:2.8rem;margin-bottom:1.5rem}.newsletter-hero-content p{color:var(--gray-text);font-size:1.1rem;line-height:1.7;max-width:500px}.newsletter-hero-stats{flex:.8;display:flex;align-items:center;justify-content:flex-end}.stat-box{border:1px solid var(--border-color);padding:2rem;width:100%;max-width:350px}.stat-box-title{color:var(--primary-green);font-size:2rem;font-family:var(--font-heading);display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem}.stat-box p{color:var(--gray-text);font-size:.9rem}.featured-article-section{display:flex;gap:4rem;margin-bottom:6rem}.featured-article{flex:2;position:relative;border-radius:12px;overflow:hidden;height:450px}.featured-article img{width:100%;height:100%;object-fit:cover}.featured-overlay{position:absolute;top:0;left:0;width:100%;height:100%;background:linear-gradient(to top,rgba(0,0,0,.8),transparent 60%);display:flex;flex-direction:column;justify-content:flex-end;padding:3rem;color:#fff}.featured-overlay .badge{background:rgba(255,255,255,.9);color:var(--primary-green);padding:.4rem .8rem;border-radius:4px;font-size:.7rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;align-self:flex-start;margin-bottom:1rem}.featured-overlay h2{color:#fff;font-size:2rem;margin-bottom:1rem}.featured-meta{font-size:.85rem;opacity:.8;display:flex;gap:1.5rem}.article-sidebar{flex:1;display:flex;flex-direction:column;justify-content:center}.sidebar-quote{border-left:3px solid var(--primary-green);padding-left:2rem}.sidebar-quote h3{font-family:var(--font-heading);font-size:1.5rem;margin-bottom:1rem;line-height:1.4}.sidebar-quote p{color:var(--gray-text);font-size:.9rem;margin-bottom:1.5rem}.dispatches-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:3rem}.dispatches-filters{display:flex;gap:1rem}.filter-btn{background:0 0;border:1px solid var(--border-color);padding:.5rem 1rem;font-size:.7rem;font-weight:700;letter-spacing:1px;color:var(--gray-text);cursor:pointer;text-transform:uppercase}.filter-btn.active,.filter-btn:hover{background:var(--primary-green);color:#fff;border-color:var(--primary-green)}.dispatches-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;margin-bottom:6rem}.dispatch-card img{width:100%;height:220px;object-fit:cover;border-radius:12px;margin-bottom:1.5rem}.dispatch-card .badge{position:absolute;top:1rem;left:1rem;background:#fff;color:var(--primary-green);padding:.3rem .6rem;border-radius:4px;font-size:.6rem;font-weight:700;letter-spacing:1px}.dispatch-card .img-container{position:relative}.dispatch-date{font-size:.75rem;color:var(--primary-green);font-weight:700;letter-spacing:1px;margin-bottom:.5rem;font-family:var(--font-body)}.dispatch-card h4{font-family:var(--font-heading);font-size:1.25rem;margin-bottom:1rem}.dispatch-card p{color:var(--gray-text);font-size:.9rem;margin-bottom:1.5rem;line-height:1.6}.subscribe-banner{background-color:var(--dark-green);border-radius:16px;padding:5rem 4rem;display:flex;justify-content:space-between;align-items:center;color:#fff;margin-bottom:4rem;position:relative;overflow:hidden}.subscribe-content{flex:1;max-width:500px;z-index:1}.subscribe-content h2{color:#fff;font-size:2.2rem;margin-bottom:1rem}.subscribe-content p{opacity:.8;font-size:1rem;line-height:1.6}.subscribe-form{flex:1;max-width:400px;z-index:1}.subscribe-form form{display:flex;flex-direction:column;gap:1rem}.subscribe-form input{padding:1rem 1.5rem;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:#fff;font-family:var(--font-body);border-radius:4px;outline:none}.subscribe-form input::placeholder{color:rgba(255,255,255,.5)}.subscribe-form button{background:#fff;color:var(--dark-green);padding:1rem;border:none;font-weight:600;text-transform:uppercase;letter-spacing:1px;cursor:pointer;border-radius:4px;transition:all .3s ease}.subscribe-form button:hover{background:var(--primary-green);color:#fff}.subscribe-note{font-size:.7rem;opacity:.5;text-transform:uppercase;letter-spacing:1px;margin-top:1rem;display:block}@keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}@media (max-width:1200px){.dispatches-grid{grid-template-columns:1fr}}@media (max-width:992px){.newsletter-hero{flex-direction:column;margin:3rem 0;gap:2rem}.newsletter-hero-stats{justify-content:flex-start}.featured-article-section{flex-direction:column;gap:3rem}.featured-article{height:350px}.dispatches-header{flex-direction:column;align-items:flex-start;gap:2rem}.dispatches-filters{overflow-x:auto;width:100%;padding-bottom:1rem}.subscribe-banner{flex-direction:column;padding:3rem 2rem;gap:3rem;text-align:center}}@media (max-width:768px){.newsletter-hero-content h1{font-size:2.2rem}.featured-overlay h2{font-size:1.5rem}}